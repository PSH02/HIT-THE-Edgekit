package main

import (
	"context"
	"flag"
	"log"
	"os"
	"os/signal"
	"syscall"
{{- if has "http"}}
	"net/http"
	"github.com/gin-gonic/gin"
{{- end}}
{{- if has "grpc"}}
	"net"
	"google.golang.org/grpc"
{{- end}}
{{- if has "postgres"}}
	"github.com/jackc/pgx/v5/pgxpool"
{{- end}}
{{- if has "redis"}}
	"github.com/redis/go-redis/v9"
{{- end}}
	"github.com/spf13/viper"
	"go.uber.org/zap"
	"golang.org/x/sync/errgroup"
)

func main() {
	configPath := flag.String("config", "configs/config.local.yaml", "path to config file")
	flag.Parse()

	viper.SetConfigFile(*configPath)
	if err := viper.ReadInConfig(); err != nil {
		log.Fatalf("read config: %v", err)
	}

	logger, _ := zap.NewProduction()
	defer logger.Sync()

	ctx, cancel := signal.NotifyContext(context.Background(), os.Interrupt, syscall.SIGTERM)
	defer cancel()
{{if has "postgres"}}
	pool, err := pgxpool.New(ctx, viper.GetString("database_url"))
	if err != nil {
		logger.Fatal("connect to database", zap.Error(err))
	}
	defer pool.Close()
	_ = pool
{{end}}
{{- if has "redis"}}
	redisOpts, {{if has "postgres"}}redisErr{{else}}err{{end}} := redis.ParseURL(viper.GetString("redis_url"))
	if {{if has "postgres"}}redisErr{{else}}err{{end}} != nil {
		logger.Fatal("parse redis url", zap.Error({{if has "postgres"}}redisErr{{else}}err{{end}}))
	}
	rdb := redis.NewClient(redisOpts)
	defer rdb.Close()
	_ = rdb
{{end}}
	g, ctx := errgroup.WithContext(ctx)
{{if has "http"}}
	g.Go(func() error {
		router := gin.New()
		router.Use(gin.Recovery())

		router.GET("/health", func(c *gin.Context) {
			c.JSON(http.StatusOK, gin.H{"status": "ok"})
		})

		addr := viper.GetString("http_addr")
		logger.Info("starting HTTP server", zap.String("addr", addr))

		srv := &http.Server{Addr: addr, Handler: router}
		go func() {
			<-ctx.Done()
			srv.Shutdown(context.Background())
		}()
		return srv.ListenAndServe()
	})
{{end}}
{{- if has "grpc"}}
	g.Go(func() error {
		addr := viper.GetString("grpc_addr")
		lis, err := net.Listen("tcp", addr)
		if err != nil {
			return err
		}

		srv := grpc.NewServer()
		logger.Info("starting gRPC server", zap.String("addr", addr))

		go func() {
			<-ctx.Done()
			srv.GracefulStop()
		}()
		return srv.Serve(lis)
	})
{{end}}
	if err := g.Wait(); err != nil && ctx.Err() == nil {
		logger.Fatal("server error", zap.Error(err))
	}

	logger.Info("shutdown complete")
}
